#!/bin/sh
# pre-commit: barra binários no índice (segurança). Artefato de build NUNCA
# versiona - o .gitignore já cobre bin/, *.vsix, *.hrb etc., mas 'git add -f'
# fura o ignore. Detecção pela PRÓPRIA heurística do git (git diff --numstat
# marca binário com '-' nas duas colunas), só em arquivos Adicionados ou
# Modificados (remover binário é permitido). Escape consciente: --no-verify.
found=$(git diff --cached --numstat --diff-filter=AM | awk -F'\t' '$1 == "-" && $2 == "-" { print $3 }')
if [ -n "$found" ]; then
  printf 'pre-commit BLOQUEOU binario(s) no commit (build/artefato nao versiona):\n' >&2
  printf '%s\n' "$found" | sed 's/^/  /' >&2
  printf 'se for intencional: git commit --no-verify\n' >&2
  exit 1
fi

# barra também o C GERADO pelo compilador Harbour (harbour/hbmk2 emitem .c
# intermediário). É texto, então a heurística de binário não pega (o sh1.c
# que vazou na raiz provou, 2026-07-11). Match ESTRUTURAL do template que o
# src/compiler/genc.c do core escreve como PRIMEIRA coisa no arquivo:
#   /*
#    * Harbour <versão> (r<rev>)      <- hb_verHarbour(), prefixo fixo
#    * <compilador C usado>           <- hb_verCompiler(), varia
#    * Generated C source from "..."  <- literal fixo
#    */
# As 5 linhas POSICIONAIS, ancoradas na linha 1 - um .c legítimo que apenas
# CITE a frase num comentário não casa. Checa o BLOB staged (git show :f),
# não a worktree.
gen=$(git diff --cached --name-only --diff-filter=AM -- '*.c' | while IFS= read -r f; do
  if git show ":$f" 2>/dev/null | head -5 | awk '
       NR==1 { ok1 = ($0 == "/*") }
       NR==2 { ok2 = ($0 ~ /^ \* Harbour /) }
       NR==3 { ok3 = ($0 ~ /^ \* /) }
       NR==4 { ok4 = ($0 ~ /^ \* Generated C source from ".*"$/) }
       NR==5 { ok5 = ($0 == " */") }
       END { exit (ok1 && ok2 && ok3 && ok4 && ok5) ? 0 : 1 }'
  then
    printf '%s\n' "$f"
  fi
done)
if [ -n "$gen" ]; then
  printf 'pre-commit BLOQUEOU C gerado pelo Harbour no commit (artefato, nao fonte):\n' >&2
  printf '%s\n' "$gen" | sed 's/^/  /' >&2
  printf 'se for intencional: git commit --no-verify\n' >&2
  exit 1
fi
exit 0
